{
  "name": "boardier",
  "version": "0.3.3",
  "description": "A free, open source, AI-focused whiteboard engine built as a React component. Themeable, extensible, 100% client-side.",
  "type": "module",
  "main": "./index.ts",
  "types": "./index.ts",
  "exports": {
    ".": "./index.ts",
    "./ai": "./ai/index.ts",
    "./themes": "./themes/index.ts"
  },
  "files": [
    "ai/",
    "core/",
    "elements/",
    "themes/",
    "tools/",
    "ui/",
    "utils/",
    "index.ts"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "docs": "ts-node scripts/parseDocsFromSource.ts",
    "changelog": "ts-node scripts/generateChangelog.ts",
    "release": "npm version"
  },
  "keywords": [
    "whiteboard",
    "canvas",
    "react",
    "drawing",
    "diagram",
    "ai",
    "mermaid",
    "open-source"
  ],
  "homepage": "https://boardier.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/Notier-AI/Boardier.git"
  },
  "bugs": {
    "url": "https://github.com/Notier-AI/Boardier/issues"
  },
  "license": "MIT",
  "author": "Notier <hello@notier.ai>",
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0",
    "react-icons": ">=5.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "react-icons": "^5.6.0",
    "typescript": "~5.8.2"
  }
}
